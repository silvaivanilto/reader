{
	"name": "pdf-reader",
	"version": "2.0.0",
	"description": "Zotero Reader",
	"main": "desktop/main.cjs",
	"scripts": {
		"build": "npm run build:all",
		"build:all": "node scripts/build-pdfjs.cjs all && webpack",
		"build:web": "node scripts/build-pdfjs.cjs web && webpack --config-name web",
		"build:zotero": "node scripts/build-pdfjs.cjs zotero && webpack --config-name zotero",
		"build:ios": "webpack --config-name ios",
		"build:android": "webpack --config-name android",
		"start": "webpack-dev-server --mode development --config-name dev",
		"view-dev": "webpack-dev-server --mode development --config-name view-dev",
		"test": "echo \"No tests yet\"",
		"desktop:run": "electron .",
		"desktop:start": "npm run build:web && electron .",
		"desktop:dist": "npm run build:web && electron-builder --win nsis portable --x64 --config.electronDist=node_modules/electron/dist"
	},
	"license": "AGPL-3.0",
	"browserslist": [
		"ff >= 60.9.0"
	],
	"dependencies": {
		"@abejellinek/readability-keep-nodes": "^1.0.0",
		"@fluent/bundle": "^0.19.1",
		"@fluent/react": "^0.15.2",
		"classnames": "^2.3.1",
		"darkreader": "^4.9.83",
		"eld": "^2.0.2",
		"epubjs": "file:epubjs/epub.js",
		"luaparse": "^0.3.1",
		"mathjax-full": "^3.2.2",
		"postcss-selector-parser": "^6.0.13",
		"prop-types": "^15.8.1",
		"queue": "^6.0.2",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"sentencex-ts": "^0.1.13-ts",
		"sorted-btree": "^1.8.1"
	},
	"devDependencies": {
		"@babel/core": "^7.18.9",
		"@babel/eslint-parser": "^7.18.9",
		"@babel/plugin-transform-runtime": "^7.18.9",
		"@babel/preset-env": "^7.18.9",
		"@babel/preset-react": "^7.18.6",
		"@babel/preset-typescript": "^7.24.7",
		"@babel/runtime": "^7.18.9",
		"@svgr/webpack": "^8.1.0",
		"@types/luaparse": "^0.2.12",
		"@types/react-dom": "^18.0.10",
		"@typescript-eslint/eslint-plugin": "^5.49.0",
		"@typescript-eslint/parser": "^5.49.0",
		"@zotero/eslint-config": "^1.0.6",
		"autoprefixer": "^10.4.7",
		"babel-loader": "^8.2.5",
		"babel-runtime": "^6.26.0",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^11.0.0",
		"css-loader": "^6.7.1",
		"css-minimizer-webpack-plugin": "^4.0.0",
		"electron": "^30.5.1",
		"electron-builder": "^24.13.3",
		"eslint": "^8.32.0",
		"eslint-plugin-react": "^7.30.1",
		"eslint-plugin-react-hooks": "^4.6.0",
		"html-webpack-plugin": "^5.5.0",
		"js-beautify": "^1.14.4",
		"mini-css-extract-plugin": "^2.6.1",
		"postcss": "^8.4.31",
		"postcss-loader": "^7.0.1",
		"postcss-rtlcss": "^5.3.0",
		"sass": "^1.54.0",
		"sass-loader": "^13.0.2",
		"svg-inline-loader": "^0.8.2",
		"terser": "^5.31.1",
		"terser-webpack-plugin": "^5.3.3",
		"ts-loader": "^9.4.2",
		"typescript": "^5.7.2",
		"webpack": "^5.99.9",
		"webpack-cli": "^4.10.0",
		"webpack-dev-middleware": "^5.3.3",
		"webpack-dev-server": "^4.9.3"
	},
	"build": {
		"appId": "org.zotero.reader.windows",
		"productName": "Zotero Reader for Windows",
		"artifactName": "zotero-reader-${version}-${os}-${arch}.${ext}",
		"directories": {
			"output": "dist-desktop"
		},
		"files": [
			"desktop/**/*",
			"build/web/**/*",
			"COPYING",
			"package.json"
		],
		"asar": true,
		"win": {
			"signAndEditExecutable": false,
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				},
				{
					"target": "portable",
					"arch": [
						"x64"
					]
				}
			]
		},
		"fileAssociations": [
			{
				"ext": "pdf",
				"name": "PDF document",
				"description": "PDF document",
				"role": "Viewer"
			},
			{
				"ext": "epub",
				"name": "EPUB document",
				"description": "EPUB document",
				"role": "Viewer"
			},
			{
				"ext": "html",
				"name": "HTML document",
				"description": "HTML document",
				"role": "Viewer"
			},
			{
				"ext": "htm",
				"name": "HTML document",
				"description": "HTML document",
				"role": "Viewer"
			}
		],
		"nsis": {
			"artifactName": "zotero-reader-${version}-setup-${arch}.${ext}",
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"perMachine": false
		},
		"portable": {
			"artifactName": "zotero-reader-${version}-portable-${arch}.${ext}"
		},
		"extraMetadata": {
			"main": "desktop/main.cjs"
		}
	}
}
